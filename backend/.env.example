# Copy to .env and fill in real values. All keys are REQUIRED (no defaults) —
# a missing key crashes startup.

APP_NAME=BhashaBridge
APP_VERSION=1.0.0
DEBUG=True

HOST=0.0.0.0
PORT=8000

PROJECT_NAME=BhashaBridge AI

# Secret used for the X-API-Key header. Change this.
API_KEY=change-me

DATABASE_URL=sqlite:///./bhashabridge.db

# Model identifiers (Hugging Face).
TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
REFINEMENT_MODEL=google/flan-t5-base

# Gated model — accept its license on HF and provide HF_TOKEN to download.
INDICTRANS2_INDIC_EN_MODEL=ai4bharat/indictrans2-indic-en-dist-200M

# slowapi rate limit for the translate route.
RATE_LIMIT=5/minute
